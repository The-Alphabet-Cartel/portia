# ============================================================
# portia-bot — Environment Configuration Template
# Copy to .env and fill in values before running.
# Sensitive values (tokens, passwords) go in Docker Secrets,
# NOT here. See docker-compose.yml for secret definitions.
# ============================================================

# --- Logging ---
PORTIA_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR | CRITICAL
PORTIA_LOG_FORMAT=human          # human (colorized) | json (structured)
PORTIA_LOG_FILE=/app/logs/portia-bot.log
PORTIA_LOG_CONSOLE=true

# --- Bot Behavior ---
PORTIA_COMMAND_PREFIX=!
PORTIA_GUILD_ID=                 # The Alphabet Cartel Fluxer guild ID

# --- Voice Channel Settings ---
PORTIA_LOBBY_CHANNEL_ID=         # Voice channel ID that Portia monitors
PORTIA_CATEGORY_ID=              # Category to create temp channels in (optional)
PORTIA_EMPTY_TIMEOUT=60          # Seconds before deleting empty temp channel (30-300)
PORTIA_CHANNEL_NAME_FORMAT={username}'s VC   # Template for new channel names
PORTIA_SWEEP_INTERVAL=300        # Seconds between reconciliation sweeps (60-600)

# --- Runtime ---
PUID=1000                        # User ID to run the bot as
PGID=1000                        # Group ID to run the bot as
