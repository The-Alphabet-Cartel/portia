# ============================================================ #
# portia-bot — Environment Configuration Template              #
# Copy to .env and fill in values before running.              #
# Sensitive values (tokens, passwords) go in Docker Secrets,   #
# NOT here. See docker-compose.yml for secret definitions.     #
# ============================================================ #
# --- Runtime ---
PUID=1000                                                      # User ID to run the bot as
PGID=1000                                                      # Group ID to run the bot as
TZ=America/Los_Angeles                                         # Bot's Timezone

# --- Bot Behavior ---
COMMAND_PREFIX=!                                               # Command Prefix to listen for

# --- Logging ---
LOG_LEVEL=INFO                                                 # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=human                                               # human (colorized) | json (structured)
LOG_CONSOLE=true                                               # Log to console
PORTIA_LOG_FILE=/app/logs/portia.log                           # Log File Location

# --- Portia Settings ---
PORTIA_GUILD_ID=                                               # Fluxer guild ID
PORTIA_LOBBY_CHANNEL_ID=                                       # Voice channel ID that Portia monitors
PORTIA_CATEGORY_ID=                                            # Category to create temp channels in (optional)
PORTIA_EMPTY_TIMEOUT=30                                        # Seconds before deleting empty temp channel (5-300)
PORTIA_CHANNEL_NAME_FORMAT={username} VC                       # Template for new channel names
PORTIA_SWEEP_INTERVAL=300                                      # Seconds between reconciliation sweeps (60-600)
